{
  "name": "librecode-monorepo",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "typescript",
    "monorepo"
  ],
  "description": "AI coding agent - TypeScript monorepo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rick000000007/LibreCode.git"
  },
  "bugs": {
    "url": "https://github.com/Rick000000007/LibreCode/issues"
  },
  "homepage": "https://github.com/Rick000000007/LibreCode#readme",
  "scripts": {
    "build": "pnpm -r build",
    "build:watch": "pnpm -r --parallel build:watch",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "link": "cd packages/cli && pnpm link --global",
    "dev": "node packages/cli/dist/index.js",
    "pack": "pnpm -r pack",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.15.4"
}
