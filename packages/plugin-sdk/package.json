{
  "name": "librecode-plugin-sdk",
  "version": "1.0.0",
  "description": "LibreCode Provider Plugin SDK — build custom provider adapters",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["librecode", "provider", "plugin", "sdk"],
  "dependencies": {
    "librecode-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
