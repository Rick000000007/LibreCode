{
  "name": "librecode-core",
  "version": "1.2.2",
  "description": "Core agent runtime for librecode",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rick000000007/LibreCode.git"
  },
  "bugs": {
    "url": "https://github.com/Rick000000007/LibreCode/issues"
  },
  "homepage": "https://github.com/Rick000000007/LibreCode#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run e2e",
    "bench": "vitest bench --run",
    "bench:ci": "tsx scripts/benchmark-ci.ts",
    "mutation": "stryker run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "librecode-memory": "^1.2.1",
    "librecode-providers": "^1.2.1",
    "librecode-tools": "^1.2.1",
    "librecode-types": "^1.2.1",
    "librecode-utils": "^1.2.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
