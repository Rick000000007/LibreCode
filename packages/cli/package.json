{
  "name": "librecode",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.0",
  "description": "AI coding agent CLI",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "librecode": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rick000000007/LibreCode.git"
  },
  "bugs": {
    "url": "https://github.com/Rick000000007/LibreCode/issues"
  },
  "homepage": "https://github.com/Rick000000007/LibreCode#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "librecode-config": "workspace:*",
    "librecode-core": "workspace:^1.2.0",
    "librecode-memory": "workspace:*",
    "librecode-providers": "workspace:*",
    "librecode-tools": "workspace:*",
    "librecode-types": "workspace:*",
    "librecode-ui": "workspace:^1.2.0",
    "librecode-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
